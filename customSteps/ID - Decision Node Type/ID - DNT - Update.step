{"creationTimeStamp":"2025-04-03T17:19:35.710Z","modifiedTimeStamp":"2025-04-09T12:39:43.659Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - DNT - Update.step","displayName":"ID - DNT - Update.step","localDisplayName":"ID - DNT - Update.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab/copy","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","uri":"/dataFlows/steps/95863551-d581-4b10-8eea-c9b7c73464ab","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Decision Node Type\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_readNodeProperties\",\n\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\"label\": \"Read node properties only\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeName\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Node name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_updNodeName\",\n\t\t\t\t\t\"type\": \"checkbox\",\n\t\t\t\t\t\"label\": \"Update node name\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"indent\": 1,\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$_readNodeProperties\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\tfalse\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeNameNew\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"New node name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_updNodeName\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\ttrue\n\t\t\t\t\t],\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$_readNodeProperties\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\tfalse\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeIcon\",\n\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\"label\": \"Node icon:\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME1\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME2\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME3\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME4\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME5\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$_readNodeProperties\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\tfalse\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeColor\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Node color:\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": false,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"max\": 13,\n\t\t\t\t\t\"stepsize\": 1,\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$_readNodeProperties\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\tfalse\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeDescription\",\n\t\t\t\t\t\"type\": \"textarea\",\n\t\t\t\t\t\"label\": \"Node description:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\",\n\t\t\t\t\t\"enabled\": [\n\t\t\t\t\t\t\"$_readNodeProperties\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\tfalse\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_readNodeProperties\": false,\n\t\t\"_nodeName\": \"\",\n\t\t\"_updNodeName\": false,\n\t\t\"_nodeNameNew\": \"\",\n\t\t\"_nodeIcon\": {\n\t\t\t\"value\": \"DNT_THEME1\"\n\t\t},\n\t\t\"_nodeColor\": 1,\n\t\t\"_nodeDescription\": \"\"\n\t}\n}","templates":{"SAS":"filename py temp;\n\ndata _null_;\n    file py;\n    put 'import requests';\n    put 'import json';\n    put 'import os';\n    put ' ';\n    put 'def updateDNT():';\n    put '    msg= '''' ';\n    put '    token= os.environ[''SAS_CLIENT_TOKEN'']';\n    put '    server= os.environ[''SAS_SERVICES_URL'']';\n    put '     ';\n    put '    url= server +\"/decisions/decisionNodeTypes\"';\n    put ' ';\n    put '    nodeName= SAS.symget(''_nodeName'').strip()';\n    put '    nodeNameNew= SAS.symget(''_nodeNameNew'').strip()';\n    put '    nodeIcon= SAS.symget(''_nodeIcon'').strip()';\n    put '    nodeColor= SAS.symget(''_nodeColor'').strip()';\n    put '    nodeDescription= SAS.symget(''_nodeDescription'').strip()';\n    put '    updNodeName= int(SAS.symget(''_updNodeName'').strip())';\n    put '    readNodeProperties= int(SAS.symget(''_readNodeProperties'').strip())';\n    put '    ';\n    put '    url= server +f\"/decisions/decisionNodeTypes?name={nodeName}\"';\n    put ' ';\n    put '    payload = \"\"';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put ' ';\n    put '    response= requests.request(\"GET\", url, headers=headers, data=payload)';\n    put '     ';\n    put '    if response.status_code == 401:';\n    put '        msg= \"Error: httpStatus \" +str(response.status_code)';\n    put '        msg= msg +\" | Message: Access token invalid. Restart SAS Studio and try again.\"';\n    put '        return msg';\n    put '    elif response.status_code != 200:';\n    put '        msg= \"Error: httpStatus = \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        nodeName_count= response.json()[''count'']';\n    put '      ';\n    put '    if nodeName_count != 1:';\n    put '        msg= f\"Could not find Decision Node Type ''{nodeName}''\"';\n    put '        return msg';\n    put '    else:';\n    put '        nodeName_id= response.json()[''items''][0][''id'']';\n    put ' ';\n    put '    url= server +f\"/decisions/decisionNodeTypes/{nodeName_id}\"';\n    put ' ';\n    put '    payload = \"\"';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put ' ';\n    put '    response= requests.request(\"GET\", url, headers=headers, data=payload)';\n    put ' ';\n    put '    if response.status_code != 200:';\n    put '        msg= \"Error: httpStatus = \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        ETag= response.headers[''Etag'']';\n    put '        curr_name= response.json()[''name'']';\n    put '        curr_hasInputs= response.json()[''hasInputs'']';\n    put '        curr_hasOutputs= response.json()[''hasOutputs'']';\n    put '        curr_type= response.json()[''type'']';\n    put '        curr_themeId= response.json()[''themeId'']';\n    put '        curr_color= response.json()[''color'']';\n    put '        curr_description= response.json()[''description'']';\n    put '    if readNodeProperties == 1:';\n    put '        SAS.symput(''nodeName'', curr_name)';\n    put '        SAS.symput(''nodeIcon'', curr_themeId)';\n    put '        SAS.symput(''nodeColor'', curr_color)';\n    put '        SAS.symput(''nodeDescription'', curr_description)';\n    put '        return \"Properties\"';\n    put '        ';\n    put '    url = server +f\"/decisions/decisionNodeTypes/{nodeName_id}\"';\n    put ' ';\n    put '    if updNodeName == 1:';\n    put '        nodeName= nodeNameNew';\n    put '    payload = json.dumps({';\n    put '      \"name\": f\"{nodeName}\",';\n    put '      \"hasInputs\": curr_hasInputs,';\n    put '      \"hasOutputs\": curr_hasOutputs,';\n    put '      \"hasProperties\": True,';\n    put '      \"type\": f\"{curr_type}\",';\n    put '      \"themeId\": f\"{nodeIcon}\",';\n    put '      \"color\": nodeColor,';\n    put '      \"description\": f\"{nodeDescription}\"';\n    put '    })';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'',';\n    put '      ''If-Match'': ETag';\n    put '    }';\n    put ' ';\n    put '    response= requests.request(\"PUT\", url, headers=headers, data=payload)';\n    put ' ';\n    put '    if response.status_code != 200:';\n    put '        msg= \"Error: httpStatus = \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        msg= f\"Updated Decision Node Type ''{nodeName}''\"';\n    put '    return msg';\n    put ' ';\n    put 'msg= updateDNT()';\n    put 'SAS.symput(''dntMsg'', msg)';\nrun;\n\nproc python infile= py;\nrun;\n\ndata _null_;\n    file print; \n    %if %NRBQUOTE(&dntMsg) = Properties %then %do;\n        put \"Node name: &nodeName\";\n        put \"Node icon: &nodeIcon\";\n        put \"Node color: &nodeColor\";\n        put \"Node dscription: &nodeDescription\";\n    %end;\n    %else %do;\n        put \"%NRBQUOTE(&dntMsg)\";\n    %end;\nrun;\n\n%symdel dntMsg / nowarn;\n%symdel nodeName / nowarn;\n%symdel nodeIcon / nowarn;\n%symdel nodeColor / nowarn;\n%symdel nodeDescription / nowarn;"}}