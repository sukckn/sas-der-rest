{"creationTimeStamp":"2025-04-03T15:03:34.468Z","modifiedTimeStamp":"2025-04-09T12:41:15.142Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - DNT - Create dummy.step","displayName":"ID - DNT - Create dummy.step","localDisplayName":"ID - DNT - Create dummy.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a/copy","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","uri":"/dataFlows/steps/df8734da-e32f-465b-83d3-df90de81de0a","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Decision Node Type\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeName\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Node name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeIcon\",\n\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\"label\": \"Node icon:\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME1\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME2\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME3\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME4\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"DNT_THEME5\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeColor\",\n\t\t\t\t\t\"type\": \"numstepper\",\n\t\t\t\t\t\"label\": \"Node color:\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"integer\": false,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"max\": 13,\n\t\t\t\t\t\"stepsize\": 1\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeDescription\",\n\t\t\t\t\t\"type\": \"textarea\",\n\t\t\t\t\t\"label\": \"Node description:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_nodeName\": \"\",\n\t\t\"_nodeIcon\": {\n\t\t\t\"value\": \"DNT_THEME1\"\n\t\t},\n\t\t\"_nodeColor\": 1,\n\t\t\"_nodeDescription\": \"\"\n\t}\n}","templates":{"SAS":"filename py temp;\n\ndata _null_;\n    file py;\n    put 'import requests';\n    put 'import json';\n    put 'import os';\n    put ' ';\n    put 'def createDNT():';\n    put '    msg= '''' ';\n    put '    token= os.environ[''SAS_CLIENT_TOKEN'']';\n    put '    server= os.environ[''SAS_SERVICES_URL'']';\n    put '     ';\n    put '    url= server +\"/decisions/decisionNodeTypes\"';\n    put ' ';\n    put '    nodeName= SAS.symget(''_nodeName'').strip()';\n    put '    nodeIcon= SAS.symget(''_nodeIcon'').strip()';\n    put '    nodeColor= SAS.symget(''_nodeColor'').strip()';\n    put '    nodeDescription= SAS.symget(''_nodeDescription'').strip()';\n    put '     ';\n    put '    payload = json.dumps({';\n    put '      \"name\": f\"{nodeName}\",';\n    put '      \"hasProperties\": True,';\n    put '      \"hasInputs\": True,';\n    put '      \"hasOutputs\": True,';\n    put '      \"inputDatagridMappable\": False,';\n    put '      \"outputDatagridMappable\": False,';\n    put '      \"inputDecisionTermMappable\": True,';\n    put '      \"outputDecisionTermMappable\": True,';\n    put '      \"hasProperties\": True,';\n    put '      \"independentMappings\": False,';\n    put '      \"type\": \"static\",';\n    put '      \"themeId\": f\"{nodeIcon}\",';\n    put '      \"color\": nodeColor,';\n    put '      \"description\": f\"{nodeDescription}\"';\n    put '    })';\n    put '     ';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put '     ';\n    put '    response= requests.request(\"POST\", url, headers=headers, data=payload)';\n    put '     ';\n    put '    if response.status_code == 401:';\n    put '        msg= \"Error: httpStatus \" +str(response.status_code)';\n    put '        msg= msg +\" | Message: Access token invalid. Restart SAS Studio and try again.\"';\n    put '        return msg';\n    put '    elif response.status_code != 201:';\n    put '        msg= \"Error: httpStatus \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" | Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        dnt_id= response.json()[''id'']';\n    put '     ';\n    put '    url= server +f\"/decisions/decisionNodeTypes/{dnt_id}/content\"';\n    put '     ';\n    put '    payload= json.dumps({';\n    put '      \"contentType\": \"DS2\",';\n    put '      \"staticContent\": \"package \\\"${PACKAGE_NAME}\\\" /inline;\\n    method execute(double VAL1, double VAL2, in_out double TOTAL);\\n    TOTAL=VAL1+VAL2;\\n   end;\\nendpackage;\",';\n    put '      \"nodeTypeSignatureTerms\": [';\n    put '        {';\n    put '          \"name\": \"TOTAL\",';\n    put '          \"dataType\": \"decimal\",';\n    put '          \"direction\": \"output\",';\n    put '          \"length\": 10,';\n    put '          \"dataGridExtension\": []';\n    put '        },';\n    put '        {';\n    put '          \"name\": \"VAL1\",';\n    put '          \"dataType\": \"decimal\",';\n    put '          \"direction\": \"input\",';\n    put '          \"length\": 10,';\n    put '          \"dataGridExtension\": []';\n    put '        },';\n    put '        {';\n    put '          \"name\": \"VAL2\",';\n    put '          \"dataType\": \"decimal\",';\n    put '          \"direction\": \"input\",';\n    put '          \"length\": 10,';\n    put '          \"dataGridExtension\": []';\n    put '        }';\n    put '      ]';\n    put '    })';\n    put '     ';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put '     ';\n    put '    response= requests.request(\"POST\", url, headers=headers, data=payload)';\n    put '     ';\n    put '    if response.status_code != 201:';\n    put '        msg= \"Error: httpStatus \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" | Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        msg= f\"Created dummy Decision Type Node ''{nodeName}''\"';\n    put '    return msg    ';\n    put ' ';\n    put 'msg= createDNT()';\n    put 'SAS.symput(''dntMsg'', msg)';\nrun;\n\nproc python infile= py;\nrun;\n\ndata _null_;\n    file print; \n    put \"%NRBQUOTE(&dntMsg)\";\nrun;\n\n%symdel dntMsg / nowarn;"}}