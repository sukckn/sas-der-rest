{"creationTimeStamp":"2025-04-03T15:26:49.194Z","modifiedTimeStamp":"2025-04-04T08:48:17.139Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - DNT - Delete.step","displayName":"ID - DNT - Delete.step","localDisplayName":"ID - DNT - Delete.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447/copy","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","uri":"/dataFlows/steps/579abc3a-fdf3-4bb8-8230-acdd0208a447","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Page 1\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeName\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Node name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_nodeName\": \"\"\n\t}\n}","templates":{"SAS":"filename py temp;\n\ndata _null_;\n    file py;\n    put 'import requests';\n    put 'import json';\n    put 'import os';\n    put ' ';\n    put 'def deleteDNT():';\n    put '    msg= '''' ';\n    put '    token= os.environ[''SAS_CLIENT_TOKEN'']';\n    put '    server= os.environ[''SAS_SERVICES_URL'']';\n    put '     ';\n    put '    url= server +\"/decisions/decisionNodeTypes\"';\n    put ' ';\n    put '    nodeName= SAS.symget(''_nodeName'').strip()';\n    put '     ';\n    put '    url= server +f\"/decisions/decisionNodeTypes?name={nodeName}\"';\n    put ' ';\n    put '    payload = \"\"';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put ' ';\n    put '    response= requests.request(\"GET\", url, headers=headers, data=payload)';\n    put '     ';\n    put '    if response.status_code == 401:';\n    put '        msg= \"Error: httpStatus \" +str(response.status_code)';\n    put '        msg= msg +\" | Message: Access token invalid. Restart SAS Studio and try again.\"';\n    put '        return msg';\n    put '    elif response.status_code != 200:';\n    put '        msg= \"Error: httpStatus = \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        nodeName_count= response.json()[''count'']';\n    put '      ';\n    put '    if nodeName_count != 1:';\n    put '        msg= f\"Could not find Decision Node Type ''{nodeName}''\"';\n    put '        return msg';\n    put '    else:';\n    put '        nodeName_id= response.json()[''items''][0][''id'']';\n    put '    ';\n    put '    url= server +f\"/decisions/decisionNodeTypes/{nodeName_id}\"';\n    put ' ';\n    put '    payload = \"\"';\n    put '    headers= {';\n    put '      ''Authorization'': ''Bearer '' +token,';\n    put '      ''Content-Type'': ''application/json'' ';\n    put '    }';\n    put ' ';\n    put '    response= requests.request(\"DELETE\", url, headers=headers, data=payload)';\n    put ' ';\n    put '    if response.status_code != 204:';\n    put '        msg= \"Error: httpStatus = \" +str(response.status_code)';\n    put '        try:';\n    put '            msg= msg +\" Message: \" +response.json()[''message'']';\n    put '        except:';\n    put '            pass';\n    put '        return msg';\n    put '    else:';\n    put '        msg= f\"Deleted Decision Node Type ''{nodeName}''\"';\n    put '    return msg';\n    put ' ';\n    put 'msg= deleteDNT()';\n    put 'SAS.symput(''dntMsg'', msg)';\nrun;\n\nproc python infile= py;\nrun;\n\ndata _null_;\n    file print; \n    put \"%NRBQUOTE(&dntMsg)\";\nrun;\n\n%symdel dntMsg / nowarn;"}}