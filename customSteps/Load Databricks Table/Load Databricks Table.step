{"creationTimeStamp":"2024-04-18T13:15:11.462Z","modifiedTimeStamp":"2024-04-18T13:22:36.974Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"Load Databricks Table.step","displayName":"Load Databricks Table.step","localDisplayName":"Load Databricks Table.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f/copy","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","uri":"/dataFlows/steps/f70a3d90-ea66-4bee-8cb8-c6926b19783f","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[{"name":"outputtable1","displayName":"outputtable1","localDisplayName":"outputtable1","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table","supportsView":false,"requiresStructure":false}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Load Databricks Table\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_SQLStmt\",\n\t\t\t\t\t\"type\": \"textarea\",\n\t\t\t\t\t\"label\": \"Set SQL Statement\",\n\t\t\t\t\t\"placeholder\": \"select * from default.xyz\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"outputtable1\",\n\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\"label\": \"Output Table:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"label\": \"Options\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_Workspace\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Databricks Workspace Id:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_cluster_name\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Databricks Cluster Name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_Token\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Databricks Token:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_databricksNotebook\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Databricks Notebook:\",\n\t\t\t\t\t\"placeholder\": \"e.g. /Shared/SASQueryTable\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_SQLStmt\": \"\",\n\t\t\"outputtable1\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"_Workspace\": \"\",\n\t\t\"_cluster_name\": \"\",\n\t\t\"_Token\": \"\",\n\t\t\"_databricksNotebook\": \"\"\n\t}\n}","templates":{"SAS":"%let _viya_outputDir= /tmp;\n\n%macro loadDatabricksData(SQLQuery, sasLibrary, sasTableName);\n\t/* remove the quotes around the macros */\n\tdata _null_;\n\tlength SQLQuery $10000;\n\tSQLQuery= &SQLQuery;\n\tsasLibrary= &sasLibrary;\n\tsasTableName= &sasTableName;\n\tcall symput(\"SQLQuery\", SQLQuery);\n\tcall symput(\"sasLibrary\", sasLibrary);\n\tcall symput(\"sasTableName\", sasTableName);\n\trun;\n\t\n\tfilename py temp;\n\tdata _null_;\n\t\tfile py;\n\t\tput 'import io';\n\t\tput 'import time';\n\t\tput 'import gzip';\n\t\tput 'import shutil';\n\t\tput 'import sys';\n\t\tput 'sys.path.insert(0, \"/shared-data/py_addon\")';\n\t\tput 'from databricks.sdk import WorkspaceClient';\n\t\tput 'from databricks.sdk.service import jobs';\n\t\tput ' ';\n\t\tput 'dbrick_outputDir= \"/tmp/outputcsv\"';\n\t\tput ' ';\n\t\tput 'viya_outputDir= SAS.symget(\"_viya_outputDir\")';\n\t\tput 'Workspace = SAS.symget(\"_Workspace\")';\n\t\tput 'notebook= SAS.symget(\"_databricksNotebook\")';\n\t\tput 'Token = SAS.symget(\"_Token\")';\n\t\tput 'cluster_name= SAS.symget(\"_cluster_name\").replace(\"''''\",\"''\")';\n\t\tput 'SQLQuery= SAS.symget(\"SQLQuery\")';\n\t\tput ' ';\n\t\tput 'w = WorkspaceClient(host=Workspace, token=Token)';\n\t\tput ' ';\n\t\tput 'cluster_id= None';\n\t\tput 'for c in w.clusters.list():';\n\t\tput '    if c.cluster_name == cluster_name:';\n\t\tput '        cluster_id= c.cluster_id';\n\t\tput '        print(c.cluster_name)';\n\t\tput '        print(c.cluster_id)';\n\t\tput '        print(c.state)';\n\t\tput '        if str(c.state) != \"State.RUNNING\":';\n\t\tput '            print(\"Cluster is not running!\")';\n\t\tput '    else:';\n\t\tput '        print(\"Cluster Name no found\")';\n\t\tput ' ';\n\t\tput'if cluster_id == None:';\n\t\tput'    print(\"Could not find Cluster: \" +cluster_name, flush=True)';\n\t\tput ' ';\n\t\tput 'notebook_path = notebook';\n\t\tput 'start_time = time.time()';\n\t\tput 'run = w.jobs.submit(run_name=f\"sdk-{time.time_ns()}\",';\n\t\tput '                    tasks=[';\n\t\tput '                        jobs.SubmitTask(existing_cluster_id= cluster_id,';\n\t\tput '                                        notebook_task=jobs.NotebookTask(notebook_path=notebook_path, base_parameters={\"SQLQuery\":SQLQuery}),';\n\t\tput '                                        task_key=f\"sdk-{time.time_ns()}\")';\n\t\tput '                    ]).result()';\n\t\tput ' ';\n\t\tput 'elapsed_time = time.time() - start_time';\n\t\tput 'print(\"Execution time in Databricks: \" +str(elapsed_time))';\n\t\tput ' ';\n\t\tput '# cleanup';\n\t\tput 'w.jobs.delete_run(run_id=run.run_id)';\n\t\tput ' ';\n\t\tput 'd= w.dbutils.fs.ls(dbrick_outputDir)';\n\t\tput 'ouputFileDir= d[0].path';\n\t\tput ' ';\n\t\tput 'outputFiles= w.dbutils.fs.ls(ouputFileDir)';\n\t\tput ' ';\n\t\tput 'for file in outputFiles:';\n\t\tput '  if (str(file.name).endswith(\".csv.gz\")):';\n\t\tput '      dataArchive= file.path';\n\t\tput ' ';\n\t\tput 'with w.dbfs.download(dataArchive) as f:';\n\t\tput '    archiveContent= f.read()';\n\t\tput ' ';\n\t\tput 'with open(viya_outputDir +\"/dricks.gz\", \"wb\") as f:';\n\t\tput '    f.write(archiveContent)';\n\t\tput ' ';\n\t\tput 'with gzip.open(viya_outputDir +\"/dricks.gz\", \"rb\") as f_in:';\n\t\tput '    with open(viya_outputDir +\"/dricks.csv\", \"wb\") as f_out:';\n\t\tput '        shutil.copyfileobj(f_in, f_out)';\n\t\tput ' ';\n\t\tput 'elapsed_time = time.time() - start_time';\n\t\tput 'print(\"Time in Python code: \" +str(elapsed_time))';\n\trun;\n\t\n\tproc python INFILE= py;\n\tquit;\n\t\n\tproc import datafile=\"/tmp/dricks.csv\"\n\t        out=&sasLibrary..&sasTableName\n\t        dbms=csv\n\t        replace;\n\trun;\n%mend loadDatabricksData;\n\n%loadDatabricksData(\"&_SQLStmt\", \"&outputtable1_lib\", \"&outputtable1_name\");\n"}}