{"creationTimeStamp":"2024-03-12T11:40:43.527Z","modifiedTimeStamp":"2024-03-18T11:45:43.198Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - Activate Lookup Tables.step","displayName":"ID - Activate Lookup Tables.step","localDisplayName":"ID - Activate Lookup Tables.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","uri":"/dataFlows/steps/b9d8ceea-58eb-4e17-989f-e5c43602b64a","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"_inputtable","displayName":"_inputtable","localDisplayName":"_inputtable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Activate lookup tables\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_inputtable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"1\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"0\"\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_lookupname\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"\",\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"c\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"visible\": false,\n\t\t\t\t\t\"readonly\": true,\n\t\t\t\t\t\"table\": \"_inputtable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_lookuptables\",\n\t\t\t\t\t\"type\": \"list\",\n\t\t\t\t\t\"label\": \"Select lookup tables:\",\n\t\t\t\t\t\"items\": {\n\t\t\t\t\t\t\"ref\": \"_lookupname\"\n\t\t\t\t\t},\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_inputtable\": {\n\t\t\t\"library\": \"WORK\",\n\t\t\t\"table\": \"_RLT_LOOKUPTABLES\"\n\t\t},\n\t\t\"_lookupname\": [\n\t\t\t{\n\t\t\t\t\"value\": \"name\"\n\t\t\t}\n\t\t],\n\t\t\"_lookuptables\": []\n\t}\n}","templates":{"SAS":"%macro activateLookupTable(lookupTableName);\n\t/* get the local server name */\n\tdata _null_;\n\t\tcall symput('server', substr(\"&_baseurl\", 1, prxmatch(\"\\/SASStudio/\\\", \"&_baseurl\") - 1));\n\trun;\n\t/* set URL to get lookup table ID */\n\tdata _null_;\n\t\turl= cat('\"', \"&server\", '/referenceData/domains?filter=eq(name,%tslit(&', 'lookupTableName))', '\"');\n\t\tcall symputx('url', url);\n\t\tput url=;\n\trun;\n\t\n\t/* call REST API to get lookup table ID */\n\tfilename lpinfo temp;\n\tproc http\n\t\tmethod= \"GET\"   \t\n\t\turl= &url\n\t\tout= lpinfo\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t\"Content-Type\"=\"application/json\";\n\trun;\t\t\n\t\n\t/***********************************************************************************************************/\n\t\n\t/* read lookup table ID */\n\tlibname lpinfo json fileref=lpinfo;\n\tdata _null_;\n\t\tset LPINFO.ITEMS;\n\t\tcall symput(\"lookupId\", ID);\n\t\tput ID=;\n\trun;\n\t\n\t/* set URL to get ETag for lookup table ID */\n\tdata _null_;\n\t\turl= cat('\"', \"&server\", '/referenceData/domains/&lookupId/currentContents', '\"');\n\t\tcall symputx('url', url);\n\t\tput url=;\n\trun;\n\t\n\t/* call REST API to get ETag lookup table ID */\n\tfilename hdinfo temp;\n\tproc http\n\t\tmethod= \"GET\"   \t\n\t\turl= &url\n\t\theaderout= hdinfo\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t\"Content-Type\"=\"application/json\";\n\trun;\t\t\n\t\n\t/* read ETag. We need it to activate the lookup table */\n\tdata _null_;\n\t\tinfile hdinfo;\n\t\tlength buffer ETag $100;\n\t\tinput; \n\t\tbuffer= strip(_infile_);\n\t\tidx= index(buffer, \"ETag:\");\n\t\tif idx > 0 then do;\n\t\t\tETag= substr(buffer, 6);\n\t\t\tcall symputx('ETag', ETag);\n\t\t\tput ETag=;\t\t\n\t\tend;\n\trun;\n\t\n\t/***********************************************************************************************************/\n\t/* activate lookup table for CAS*/\n\tproc http\n\t\tmethod= \"PATCH\"   \t\n\t\turl= &url\n\t\tin= '[{\"op\": \"copy\",\"from\": \"/@current\", \"path\": \"/@current/environments/cas\"}]'\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t'Content-Type'='application/json'\n\t\t\t'If-Match'= %tslit(&ETag);\n\trun;\n\t%put Activated ==> &lookupTableName;\n%mend activateLookupTable;\n\n%macro activateSelectedLookupTables();\n\t%let i=1;\n\t%do %while (&i <= &_lookuptables_count);\n\t\t%activateLookupTable(%trim(&&_lookuptables_&i));\n\t\t%let i= %eval(&i+1);\n\t%end;\n%mend activateSelectedLookupTables;\n\n%activateSelectedLookupTables();"}}