{"creationTimeStamp":"2024-03-01T14:22:41.072Z","modifiedTimeStamp":"2024-03-04T14:58:25.298Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - Retrieve Decision Code.step","displayName":"ID - Retrieve Decision Code.step","localDisplayName":"ID - Retrieve Decision Code.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","uri":"/dataFlows/steps/ebacf557-fbc6-4ffa-838e-8d3c9b38ef3a","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"_page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Retrieve Code\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_nodeType\",\n\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\"label\": \"Select artefact to generate code for:\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Decision Flow\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Rule Set\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_dec_txt1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"If the decision flow name is unique you can use the decision flow name, otherwise use the decision flow id.\",\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Decision Flow\"\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_rs_txt1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"If the rule set name is unique you can use the rule set name, otherwise use the rule set id.\",\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Rule Set\"\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_decisionRB\",\n\t\t\t\t\t\"type\": \"radiogroup\",\n\t\t\t\t\t\"label\": \"\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Decision Flow Name\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Decision Flow Id\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Decision Flow\"\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_rulesetRB\",\n\t\t\t\t\t\"type\": \"radiogroup\",\n\t\t\t\t\t\"label\": \"\",\n\t\t\t\t\t\"items\": [\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Rule Set Name\"\n\t\t\t\t\t\t},\n\t\t\t\t\t\t{\n\t\t\t\t\t\t\t\"value\": \"Rule Set Id\"\n\t\t\t\t\t\t}\n\t\t\t\t\t],\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Rule Set\"\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_decisionflowname\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Decision Flow Name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Decision Flow\"\n\t\t\t\t\t\t],\n\t\t\t\t\t\t\"&\",\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_decisionRB\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Decision Flow Name\"\n\t\t\t\t\t\t]\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_rulesetname\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Rule Set Name:\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Rule Set\"\n\t\t\t\t\t\t],\n\t\t\t\t\t\t\"&\",\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_rulesetRB\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Rule Set Name\"\n\t\t\t\t\t\t]\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_decisionflowid\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Decision Flow Id:\",\n\t\t\t\t\t\"regexp\": \"^[0-9a-z]{8}-[0-9a-z]{4}-[0-9a-z]{4}-[0-9a-z]{4}-[0-9a-z]{12}\",\n\t\t\t\t\t\"placeholder\": \"i.e.: 1qazxsw2-1234-aq12-sde3-234r-123ewsdfrt65\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Decision Flow\"\n\t\t\t\t\t\t],\n\t\t\t\t\t\t\"&\",\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_decisionRB\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Decision Flow Id\"\n\t\t\t\t\t\t]\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_rulesetid\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"Rule Set Id:\",\n\t\t\t\t\t\"regexp\": \"^[0-9a-z]{8}-[0-9a-z]{4}-[0-9a-z]{4}-[0-9a-z]{4}-[0-9a-z]{12}\",\n\t\t\t\t\t\"placeholder\": \"i.e.: 1qazxsw2-1234-aq12-sde3-234r-123ewsdfrt65\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Rule Set\"\n\t\t\t\t\t\t],\n\t\t\t\t\t\t\"&\",\n\t\t\t\t\t\t[\n\t\t\t\t\t\t\t\"$_rulesetRB\",\n\t\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\t\"Rule Set Id\"\n\t\t\t\t\t\t]\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_codedir\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select Rule Set Code Folder:\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"Select folder on SAS Server\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_masModulePath\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"ESP MAS Module Path\",\n\t\t\t\t\t\"placeholder\": \"i.e.: @ESP_PROJECT_HOME@/files/\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t\"$_nodeType\",\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t\"Decision Flow\"\n\t\t\t\t\t]\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_nodeType\": {\n\t\t\t\"value\": \"Decision Flow\"\n\t\t},\n\t\t\"_decisionRB\": {\n\t\t\t\"value\": \"Decision Flow Name\"\n\t\t},\n\t\t\"_rulesetRB\": {\n\t\t\t\"value\": \"Rule Set Name\"\n\t\t},\n\t\t\"_decisionflowname\": \"\",\n\t\t\"_rulesetname\": \"\",\n\t\t\"_decisionflowid\": \"\",\n\t\t\"_rulesetid\": \"\",\n\t\t\"_codedir\": \"\",\n\t\t\"_masModulePath\": \"@ESP_PROJECT_HOME@/files/\"\n\t}\n}","templates":{"SAS":"/***************************************************************************\n* Custom Step: ID Retrieve Decision Code\n* --------------------------------------------------------------------------\n* The ID Retrieve Decision Code step will generate the DS2 code for a \n* decision flow or rule set wich can be used in an ESP project.\n* The step will output the code to a directory - wich you can set in the UI. \n* The rule set code will be put into one file where as the decision flow will \n* be put into several file - one file for each node in the decision flow. This \n* is a requirement when loading the code in ESP. For a desicion flow the step \n* also ouputs a file with XML code that can be used in the ESP project for \n* setting in MAS module.\n* --------------------------------------------------------------------------\n* Note: Macros starting with an underscore contain UI variable values\n***************************************************************************/\n\n%let tmpDir= /tmp/;\n%let infoFile= ~httpout.txt;\n\n%let codeDir= %substr(&_codedir, 11);\n%let folderserver= %substr(&_codedir, 1, 9);\n\n/* --------------------------------------------------------------------------- */\n/* determin if we generate code for decision flow or rule set                  */\n/* and set macros appropriately                                                */\n/* --------------------------------------------------------------------------- */\n%if &_nodeType = Decision Flow %then %do;\n\t%let nodeType= decision flow;\n\t%let nodeType2= Decision Flow;\n\t%let nodeTypeRB= &_decisionRB;\n\t%let nodeName= &_decisionflowname;\n\t%let nodeId= &_decisionflowid;\n\t%let endpoint= /decisions/flows;\n\t%let fPrefix= df_;\n%end;\n%else %do;\n\t%let nodeType= rule set;\n\t%let nodeType2= Rule Set;\n\t%let nodeTypeRB= &_rulesetRB;\n\t%let nodeName= &_rulesetname;\n\t%let nodeId= &_rulesetid;\n    %let endpoint= /businessRules/ruleSets;\n\t%let fPrefix= rs_;\n%end;\n\n/***************************************************************************/\n/* Macro splitDecisionCode()                                               */ \n/* ----------------------------------------------------------------------- */\n/* The macro splits the decision code file into several files. One file    */\n/* for each DS2 package. This is necessary to load the code into MAS in    */\n/* the ESP project.                                                        */\n/***************************************************************************/\n%macro splitDecisionCode();\n\t/* Python code to to split the decision code into several files */\n\t/* we have to put it in a file first as otherwise we cannot call proc python in a macro */\n\tfilename PY temp;\n\tdata _null_;\n\t\tfile PY;\t\n\t\tput \"import os\";\n\t\tput \"codePath= SAS.symget('codeDir') +'/'\";\n\t\tput \"codeFileName= SAS.symget('codeFileName')\";\n\t\tput \"fPreFix= SAS.symget('fPrefix')\";\n\t\tput \"masModulePath= SAS.symget('_masModulePath')\";\n\t\tput \"######################################################\";\n\t\tput \"# Read decision flow code file and split into several file\";\n\t\tput \"# one file per ds2 package\";\n\t\tput \"outFiles= {}\";\n\t\tput \"outFile= ''\";\n\t\tput \"fileCnt= 0\";\n\t\tput \"with open(codePath +fPreFix +codeFileName +'.sas', 'r') as f:\";\n\t\tput \"    for line in f:\";\n\t\tput \"        outFile += line\";\n\t\tput \"        line= line.replace(' ', '')\";\n\t\tput \"        if line.find('endpackage;') == 0:\";\n\t\tput \"            outFiles[fileCnt]= outFile\";\n\t\tput \"            outFile= ''\";\n\t\tput \"            fileCnt+= 1\";\n\t\tput \" \";\n\t\tput \"######################################################\";\n\t\tput \"#write output files\";\n\t\tput \"# one file per ds2 package\";\n\t\tput \"fileCnt= len(outFiles)           \";\n\t\tput \"for file in outFiles:\";\n\t\tput \"    fo= open(codePath +fPreFix +codeFileName +f'_{fileCnt:002d}' +'.sas', 'w')\";\n\t\tput \"    fo.write(outFiles[file])\";\n\t\tput \"    fo.close()\";\n\t\tput \"    fileCnt-= 1\";\n\t\tput \" \";\n\t\tput \"######################################################\";\n\t\tput \"#generate XML for MAS Module in ESP project\";\n\t\tput \"#this XML can be copied into the ESP project \";\n\t\tput \"#this will make it easier to register the files in ESP\";\n\t\tput \" \";\n\t\tput \"masModuleStart= '<mas-modules>\\n'\";\n\t\tbuffer= 'masModule= \"\"\"  <mas-module module=\"%s\" language=\"ds2\" func-names=\"execute\">\\n    <code-file><![CDATA[%s%s%s]]></code-file>\\n  </mas-module>\\n\"\"\"';\n\t\tput buffer;\n\t\tput \"masModuleEnd= '</mas-modules>'\";\n\t\tput \" \";\n\t\tput \"fmm= open(codePath +fPreFix +codeFileName +'_masmodule' +'.xml', 'w')\";\n\t\tput \"fmm.write(masModuleStart)\";\n\t\tput \"fileCnt= len(outFiles)           \";\n\t\tput \"for file in outFiles:\";\n\t\tput \"    fmm.write(masModule % (codeFileName +f'_{fileCnt:002d}', masModulePath, fPreFix, codeFileName +f'_{fileCnt:002d}' +'.sas'))\";\n\t\tput \"    fileCnt-= 1\";\n\t\tput \"fmm.write(masModuleEnd)\";\n\t\tput \"fmm.close()\";\n\t\tput \"os.remove(codePath +fPreFix +codeFileName +'.sas')\";\n\t\tput \"SAS.symput('FileMin', '01') \";\n\t\tput \"SAS.symput('FileMax', f'{len(outFiles):002d}') \";\n\trun;\n\t\n\tproc python infile=PY;\n\tquit;\n\n\t%global codeFileMin codeFileMax;\n\t%let codeFileMin= &FileMin;\n\t%let codeFileMax= &FileMax;\n\n%mend splitDecisionCode;\t\n\n/***************************************************************************/\n/* Macro retrieveCode()                                                    */ \n/* ----------------------------------------------------------------------- */\n/* The macro contains the logic to get the code for the decsion flow/rule  */\n/* set from Intelligent Decisioning and puts it into a file.               */\n/***************************************************************************/\n%macro retrieveCode();\n/**************************************************************************************************/\n\t/* Check output code folder setting */\n\tdata _null_;\n\t\tfile print;\t\n\t\tfolderserver= \"&folderserver\";\n\t\tif folderserver ~= \"sasserver\" then do;\n\t\t\tput \"ERROR: Wrong code file folder!\";\n\t\t\tput \"Please select a folder from sasserver not from sascontent.\";\n\t\t\terror \"ERROR: Wrong code file folder! The folder needs to be from sasserver!\";\n\t\t\tabort;\n\t\tend;\n\trun;\n\t\n\t/**************************************************************************************************/\n\t/* get the local server name */\n\tdata _null_;\n\t\tcall symput('server', substr(\"&_baseurl\", 1, prxmatch(\"\\/SASStudio/\\\", \"&_baseurl\") - 1));\n\trun;\n\t\n\n\t/* --------------------------------------------------------------------------- */\n\t/* looking up node information based in node id                                */\n\t/* --------------------------------------------------------------------------- */\n\t%if &nodeTypeRB = Rule Set Id or &nodeTypeRB = Decision Flow Id %then %do;\n\t\t/***********************************************************************************************************/\n\t\t/* set URL to get node information for node id*/\n\t\tdata _null_;\n\t\t\turl= cat('\"', \"&server\", '&endpoint./&nodeId', '\"');\n\t\t\tcall symputx('url', url);\n\t\t\tput url=;\n\t\trun;\n\t\t\n\t\t/* get node information */\n\t\tfilename RS \"&tmpDir.&infoFile\";\n\t\tproc http\n\t\t\tmethod= \"GET\"   \t\n\t\t\turl= &url\n\t\t\tout= RS\n\t\t    oauth_bearer= sas_services;\n\t\t \theaders \n\t\t    \t'Content-Type'='application/json';\n\t\tquit;\n\t\n        /* Python code to read the return data from the REST call */\n        /* we have to put it in a file first as otherwise we cannot call proc python in a macro */\n\t\tfilename PY temp;\n\t\tdata _null_;\n\t\t\tfile PY;\t\n\t\t\tput \"import json\";\n\t\t\tput \" \";\n\t\t\tput \"fileTmpDir= SAS.symget('tmpDir')\";\n\t\t\tput \"fileName= SAS.symget('infoFile')\";\n\t\t\tput \" \";\n\t\t\tput \"with open(fileTmpDir+fileName, 'r') as f:\";\n\t\t\tput \"    rsInfo= json.loads(f.read())\";\n\t\t\tput \"try:\";\n\t\t\tput \"    SAS.symput('nodeRc', 1)\";\n\t\t\tput \"    SAS.symput('nodeId', rsInfo['id'])\";\n\t\t\tput \"    SAS.symput('nodeName', rsInfo['name'])\";\n\t\t\tput \"    SAS.symput('codeFileName', rsInfo['name'].replace(' ', '_'))\";\n\t\t\tput \"except:\";\n\t\t\tput \"    SAS.symput('nodeRc', 3)\";\n\t\trun;\n\t\t\n\t\tproc python infile=PY;\n\t\tquit;\t\n\t%end;\n\t/* --------------------------------------------------------------------------- */\n\t/* looking up node information based in node name                                */\n\t/* --------------------------------------------------------------------------- */\n\t%else %do;\n\t\t/***********************************************************************************************************/\n\t\t/* set URL to get node information for node name*/\n\t\tdata _null_;\n\t\t\turl= cat('\"', \"&server\", '&endpoint.?filter=eq(name,%tslit(&', 'nodeName))', '\"');\n\t\t\tcall symputx('url', url);\n\t\t\tput url=;\n\t\trun;\n\t\t\n\t\t/* get node information */\n\t\tfilename DECRS \"&tmpDir.&infoFile\";\n\t\tproc http\n\t\t\tmethod= \"GET\"   \t\n\t\t\turl= &url\n\t\t\tout= DECRS\n\t\t    oauth_bearer= sas_services;\n\t\t \theaders \n\t\t    \t'Content-Type'='application/json';\n\t\tquit;\n\t\t\n\t\t/* read node info from http return */\n\t\t/* we first need to write the Pyhton code to a file because we execute it in a macro */\n\t\tfilename CO temp;\n\t\tdata _null_;\n\t\t\tfile CO;\t\n\t\t\tput \"import json\";\n\t\t\tput \" \";\n\t\t\tput \"fileTmpDir= SAS.symget('tmpDir')\";\n\t\t\tput \"fileName= SAS.symget('infoFile')\";\n\t\t\tput \" \";\n\t\t\tput \"with open(fileTmpDir+fileName, 'r') as f:\";\n\t\t\tput \"    rsInfo= json.loads(f.read())\";\n\t\t\tput \" \";\n\t\t\tput \"if rsInfo['count'] == 0:\";\n\t\t\tput \"    SAS.symput('nodeRc', '0')\";\n\t\t\tput \"elif rsInfo['count'] == 1:\";\n\t\t\tput \"    SAS.symput('nodeRc', '1')\";\n\t\t\tput \"    SAS.symput('nodeId', rsInfo['items'][0]['id'])\";\n\t\t\tput \"    SAS.symput('nodeName', rsInfo['items'][0]['name'])\";\n\t\t\tput \"    SAS.symput('codeFileName', rsInfo['items'][0]['name'].replace(' ', '_'))\";\n\t\t\tput \"elif rsInfo['count'] > 1:\";\n\t\t\tput \"    SAS.symput('nodeRc', '2')\";\n\t\n\t\trun;\n\t\tproc python infile= co;\n\t\tquit;\n\t%end;\n\t\n\t/* the hppt call returned an id for the node */\n\t%if &nodeRc = 1 %then %do;\n\t\t/***********************************************************************************************************/\n\t\t/* set URL to get node code */\n\t\tdata _null_;\n\t\t\turl= cat(\"'\", \"&server\", \"&endpoint./&nodeId\", '/code?codeTarget=MICROANALYTICSERVICE&lookupMode=inline&isGeneratingRuleFiredColumn=false', \"'\");\n\t\t\tcall symputx('url', url);\n\t\t\tput url=;\n\t\trun;\n\t\t\n\t\t/* retrieve node code */\n\t\t/* the REST call will write the output to the code file */\n\t\tfilename DECRS \"&codeDir./&fPrefix.&codeFileName..sas\";\n\t\tproc http\n\t\t\tmethod= \"GET\"   \t\n\t\t\turl= &url\n\t\t\tout= DECRS\n\t\t    oauth_bearer= sas_services;\n\t\t \theaders \n\t\t    \t'Content-Type'='text/vnd.sas.source.ds2';\n\t\tquit;\n\t\t\n\t\t/* if we generate code for a decison flow we need to split the code file */\n\t\t%if &nodeTypeRB = Decision Flow Id %then %do;\n\t\t\t%splitDecisionCode();\n\t\t\n\t\t\t\t/* write message to result screen in the UI */\n\t\t\t\tdata _null_;\n\t\t\t\t\tfile print;\n\t\t\t\t\tput \"&nodeType2: '&nodeName'\";\n\t\t\t\t\tput\" \";\n\t\t\t\t\tput \"Generated code files: &fPrefix.&codeFileName._&codeFileMin..sas ... &fPrefix.&codeFileName._&codeFileMax..sas\";\n\t\t\t\t\tput \"Generated XML for ESP MAS Module: &fPrefix.&codeFileName._masmodule.xml\";\n\t\t\t\t\tput \"The files are in folder &codeDir\";\n\t\t\t\trun;\n\t\t%end;\n\t\t%else %do;\n\t\t\t/* write message to result screen in the UI */\n\t\t\tdata _null_;\n\t\t\t\tfile print;\n\t\t\t\tput \"&nodeType2: '&nodeName'\";\n\t\t\t\tput\" \";\n\t\t\t\tput \"Generated code file: &fPrefix.&codeFileName..sas\";\n\t\t\t\tput \"The file is in folder &codeDir\";\n\t\t\trun;\n\t\t%end;\n\t%end;\n\t/* the hppt call could not find the node */\n\t%else %if &nodeRc = 0 %then %do;\n\tdata _null_;\n\t\tfile print;\t\n\t\tput \"ERROR: Could not find &nodeType '&nodeName'!\";\n\t\tput \"Check if spelling is correct (case sensetive) or if &nodeType exists.\";\n\t\terror \"ERROR: Could not find &nodeType name!\";\n\t\tabort;\n\trun;\n\t%end;\n\t/* the hppt call found more than one node for the searched name*/\n\t%else %if &nodeRc = 2 %then %do;\n\tdata _null_;\n\t\tfile print;\t\n\t\tput \"ERROR: More than one &nodeType with name: '&nodeName'!\";\n\t\tput \"Use rule set Id instead!\";\n\t\terror \"ERROR: More than one &nodeType with name: '&nodeName'!\";\n\t\tabort;\n\trun;\n\t%end;\n\t/* the hppt call could not find the node id */\n\t%else %if &nodeRc = 3 %then %do;\n\tdata _null_;\n\t\tfile print;\t\n\t\tput \"ERROR: Could not find &nodeType for &nodeType id: &nodeId\";\n\t\tput \"Ensure that the &nodeType id is correct.\";\n\t\terror \"ERROR: Could not find &nodeType for &nodeType id: &nodeId\";\n\t\tabort;\n\trun;\n\t%end;\n%mend retrieveCode;\n\n/* generate code for the decision flow / rule set */\n%retrieveCode()\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros variables used in this step                                 */\n/* --------------------------------------------------------------------------- */\n%symdel tmpDir;\n%symdel infoFile;\n%symdel codeDir;\n%symdel folderserver;\n%symdel nodeType;\n%symdel nodeType2;\n%symdel nodeTypeRB;\n%symdel nodeName;\n%symdel nodeId;\n%symdel endpoint;\n%symdel fPrefix;\n%symdel codeFileMin;\n%symdel codeFileMax;\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros used in this step                                           */\n/* --------------------------------------------------------------------------- */\n%sysmacdelete retrieveCode; \n%sysmacdelete splitDecisionCode;\n"}}