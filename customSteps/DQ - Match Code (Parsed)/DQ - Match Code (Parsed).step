table\": {\n\t\t\t\"library\": \"sashelp\",\n\t\t\t\"table\": \"cs_dqmcparsed\"\n\t\t},\n\t\t\"_outputtable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"_locale_col\": [\n\t\t\t{\n\t\t\t\t\"value\": \"locale\"\n\t\t\t}\n\t\t],\n\t\t\"_definition_col\": [\n\t\t\t{\n\t\t\t\t\"value\": \"definition\"\n\t\t\t}\n\t\t],\n\t\t\"_token_col\": [\n\t\t\t{\n\t\t\t\t\"value\": \"token\"\n\t\t\t}\n\t\t],\n\t\t\"_matchcode_col\": {\n\t\t\t\"length\": 100\n\t\t},\n\t\t\"_sensitivity\": 80,\n\t\t\"_locale_lable\": null,\n\t\t\"_definition\": null,\n\t\t\"_token_1\": null,\n\t\t\"_token_incol_1\": []\n\t},\n\t\"promptHierarchies\": [\n\t\t{\n\t\t\t\"name\": \"LocaleHierarchy\",\n\t\t\t\"levels\": [\n\t\t\t\t\"_locale_lable\",\n\t\t\t\t\"_definition\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_1\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_1\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_2\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_2\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_3\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_3\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_4\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_4\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_5\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_5\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_6\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_6\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_7\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_7\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_8\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_8\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_9\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_9\"\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"name\": \"Token_10\",\n\t\t\t\"levels\": [\n\t\t\t\t\"LocaleHierarchy\",\n\t\t\t\t\"_token_10\"\n\t\t\t]\n\t\t}\n\t]\n}","templates":{"SAS":"%macro setLocale();\n\t%global locale;\n\t%local _locale_selected;\n\t%let _locale_selected= %trim(&_locale_lable);\n\t%if \"&_locale_selected\" = \"English - United Kingdom\" %then \n\t\t%let locale= ENGBR;\n\t%else %if \"&_locale_selected\" = \"English - United States\" %then \n\t\t%let locale= ENUSA;\n\t%else %if \"&_locale_selected\" = \"English - Canada\" %then \n\t\t%let locale= ENCAN;\n\t%else %if \"&_locale_selected\" = \"French - Canada\" %then \n\t\t%let locale= FRCAN;\n\t%else %if \"&_locale_selected\" = \"French - France\" %then \n\t\t%let locale= FRFRA;\n\t%else %if \"&_locale_selected\" = \"German - Germany\" %then \n\t\t%let locale= DEDEU;\n\t%else %if \"&_locale_selected\" = \"Italian - Italy\" %then \n\t\t%let locale= ITITA;\n\t%else %if \"&_locale_selected\" = \"Spanish - Spain\" %then \n\t\t%let locale= ESESP;\n\t%else %do;\n\t\tdata _null_;\n\t\t\tputlog \"ERROR: Could not map QKB locale. Check source code for step 'DQ - Match Code Parsed' if locale is mapped.\";\n\t\t\tabort;\n\t\trun;\n\t%end;\n\t%put &=locale;\n%mend setLocale;\n\n%macro setTokens(maxToken=10);\n\t%global tokenCnt;\n\t%let tokenCnt= 0;\n\t%do i=1 %to &maxToken;\n\t\t%if &&_token_&i ne AND &&_token_incol_&i._count = 1 %then %do;\n\t\t\t%global parsedValue_&i;\n\t\t\t%let parsedValue_&i= parsedValue=dqParseTokenPut(parsedValue, &&_token_incol_&i, \"%trim(&&_token_&i)\", parseDefn, \"&locale\");\n\t\t\t%let tokenCnt= &i;\n\t\t%end;\n\t%end;\n\t%put &=tokenCnt;\n%mend setTokens;\n\n%macro step_dqmacthcodeparsed();\n\t/*set the locale from the term selected in the locale drop down list and initialize QKB with locale*/\n\t%setLocale();\n\t%DQLOAD(DQLOCALE=(&locale));\n\n\t/* set the statement for dqParseTokenPut() */\n\t%setTokens();\n\t\n\t/*generate the parsed match code */\n\tdata &_outputtable (drop=parsedValue parseDefn);\n\t\tset &_inputtable;\n\t\tlength &_matchcode_col_name parseDefn $100;\n\t\tlength parsedValue $2500;\n\n\t\tparseDefn= dqMatchInfoGet(\"%trim(&_definition)\", \"&locale\");\n\t\t/* if dqMatchInfoGet() did not find a definition we use try the input definition */\n\t\tif length(parseDefn) = 1 then\n\t\t\tparseDefn= \"%trim(&_definition)\";\n*put parseDefn=;\n\n\t\t%do i=1 %to &tokenCnt;\n\t\t\t&&parsedValue_&i;\n\t\t%end ;\t\n*put parsedValue=;\n\t\t&_matchcode_col_name=dqMatchParsed(parsedValue, \"%trim(&_definition)\", &_sensitivity, \"&locale\");\n\trun;\n%mend step_dqmacthcodeparsed;\n\n%step_dqmacthcodeparsed();"}}