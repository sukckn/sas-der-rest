{"creationTimeStamp":"2024-02-21T15:30:37.335Z","modifiedTimeStamp":"2024-02-26T15:02:33.797Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - Export Custom Functions.step","displayName":"ID - Export Custom Functions.step","localDisplayName":"ID - Export Custom Functions.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","uri":"/dataFlows/steps/14955ec0-42df-4e7e-b6d4-4cc38e0bb9c1","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"_inputtable","displayName":"_inputtable","localDisplayName":"_inputtable","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table"}],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Export Custom Functions\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_inputtable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table:\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"readonly\": false,\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t0,\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t1\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_categoryCol\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"categoryCol\",\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"visible\": false,\n\t\t\t\t\t\"readonly\": true,\n\t\t\t\t\t\"table\": \"_inputtable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_categoryName\",\n\t\t\t\t\t\"type\": \"dropdown\",\n\t\t\t\t\t\"label\": \"Select a Custom Function Category:\",\n\t\t\t\t\t\"items\": {\n\t\t\t\t\t\t\"ref\": \"_categoryCol\"\n\t\t\t\t\t},\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_custNameCol\",\n\t\t\t\t\t\"type\": \"columnselector\",\n\t\t\t\t\t\"label\": \"custNameCol\",\n\t\t\t\t\t\"order\": false,\n\t\t\t\t\t\"columntype\": \"a\",\n\t\t\t\t\t\"max\": 1,\n\t\t\t\t\t\"min\": 1,\n\t\t\t\t\t\"visible\": false,\n\t\t\t\t\t\"readonly\": true,\n\t\t\t\t\t\"table\": \"_inputtable\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_customFunction\",\n\t\t\t\t\t\"type\": \"list\",\n\t\t\t\t\t\"label\": \"Select a Customer Function to Export:\",\n\t\t\t\t\t\"items\": {\n\t\t\t\t\t\t\"ref\": \"_custNameCol\"\n\t\t\t\t\t},\n\t\t\t\t\t\"max\": null,\n\t\t\t\t\t\"min\": null,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_outputFolder\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select Output Folder:\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"Select folder on SAS Server\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": []\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_inputtable\": {\n\t\t\t\"library\": \"WORK\",\n\t\t\t\"table\": \"_RCF_IDCUSTOMFUNCTIONS\"\n\t\t},\n\t\t\"_categoryCol\": [\n\t\t\t{\n\t\t\t\t\"value\": \"categoryName\"\n\t\t\t}\n\t\t],\n\t\t\"_categoryName\": null,\n\t\t\"_custNameCol\": [\n\t\t\t{\n\t\t\t\t\"value\": \"functionName\"\n\t\t\t}\n\t\t],\n\t\t\"_customFunction\": [],\n\t\t\"_outputFolder\": \"\"\n\t},\n\t\"promptHierarchies\": [\n\t\t{\n\t\t\t\"name\": \"PromptHierarchy\",\n\t\t\t\"levels\": [\n\t\t\t\t\"_categoryName\",\n\t\t\t\t\"_customFunction\"\n\t\t\t]\n\t\t}\n\t]\n}","templates":{"SAS":"/***************************************************************************\n* Custom Step:ID - Export Custom Functions\n* --------------------------------------------------------------------------\n* The Export Custom Functions step exports custom functions from Intelligent \n* Decisioning. The step works together with step Read Custom Functions. \n* Read Custom Functions needs to run before step Export Custom Function. \n* --------------------------------------------------------------------------\n* Note: Macros starting with an underscore contain UI variable values\n***************************************************************************/\n%let tmpDir= /tmp/;\n%let funcCode= ~custfunccode.txt;\n\n/***************************************************************************/\n/* Macro exportFunction()                                                  */ \n/* ----------------------------------------------------------------------- */\n/* The macro reads the custom function information and outputs            */\n/* the information to a file in json structure so that it can be           */\n/* imported again.                                                         */\n/***************************************************************************/\n%macro exportFunction(customFunctionUI);\n\t/* putting the value into quote to use it in proc sql */\n\t%let customFunction= \"&customFunctionUI\";\n\t%let categoryName= \"&_categoryName\";\n\t\n\t/* Select  function id and category name based on UI input */\n\tproc sql noprint;\n\tSELECT id, categoryName\n\t  INTO :funcId, :catName \n\t  FROM &_inputtable \n\t WHERE functionName = &customFunction\n\t   AND categoryName = &categoryName;\n\trun; quit;\n\t\n\t/* ---------------------------------------------------------------------- */\n\t/* Set URL to get custom function information */\n\tdata _null_;\n\t\turl= cat('\"', \"&server\", '/businessRules/functions/', \"&funcId\", '\"');\n\t\tcall symputx('url', url);\n\t\tput url=;\n\trun;\n\t\n\t/* ---------------------------------------------------------------------- */\n\t/* Get custom function information */\n\tfilename CUSTFUNC \"&tmpDir.&funcCode\";\n\tproc http\n\t\tmethod= \"GET\"   \t\n\t\turl= &url\n\t\tout= CUSTFUNC\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t'Content-Type'='application/json';\n\tquit;\n\t\n\t/* ---------------------------------------------------------------------- */\n\t/* Python script to read the joson structure for the custom function */\n\tfilename PCODE TEMP;\n\tdata _null_;\n\t\tfile PCODE;\n\t\tput \"import json\";\n\t\tput \" \";\n\t\tput \"tmpDir= SAS.symget('tmpDir')\";\n\t\tput \"funcCode= SAS.symget('funcCode')\";\n\t\tput \" \";\n\t\tput \"#read return info from custom fulction REST call\";\n\t\tput \"f= open(tmpDir+funcCode, 'r')\";\n\t\tput \"custFuncInfo= json.loads(f.read())\";\n\t\tput \"f.close()\";\n\t\tput \" \";\n\t\tput \"#go through json to read the tokens we need when importing the custom function again\";\n\t\tput \"custFunc= {}\";\n\t\tput \"custFunc['name']= custFuncInfo['name']\";\n\t\tput \"custFunc['description']= custFuncInfo['description']\";\n\t\tput \"custFunc['category']= SAS.symget('catName') #here we set the real category name as we read its id when we import the function\";\n\t\tput \"try:\";\n\t\tput \"    custFunc['returnType']= custFuncInfo['returnType']\";\n\t\tput \"except:\";\n\t\tput \"    pass\";\n\t\tput \"custFunc['hidden']= custFuncInfo['hidden']\";\n\t\tput \"custFunc['nameQuoted']= custFuncInfo['nameQuoted']\";\n\t\tput \"custFunc['signature']= []\";\n\t\tput \"custFunc['code']= custFuncInfo['code']\";\n\t\tput \" \";\n\t\tput \"for parameter in custFuncInfo['signature']:\";\n\t\tput \"    signature= {}\";\n\t\tput \"    signature['type']= parameter['type']\";\n\t\tput \"    signature['name']= parameter['name']\";\n\t\tput \"    signature['inOut']= parameter['inOut']\";\n\t\tput \"    signature['nameQuoted']= parameter['nameQuoted']\";\n\t\tput \"    custFunc['signature'].append(signature)\";\n\t\tput \" \";\n\t\tput \"#output the custom function to a file\";\n\t\tput \"f= open(SAS.symget('outputFolder') +'/cf_' +custFuncInfo['name'] +'.json', 'w')\";\n\t\tput \"f.write(json.dumps(custFunc))\";\n\t\tput \"f.close()\";\n\trun;\n\tproc python infile= PCODE; quit;\n%mend exportFunction;\n\n/***************************************************************************/\n/* Macro loopThroughFunctionList()                                         */ \n/* ----------------------------------------------------------------------- */\n/* The macro loops through the list of custom function in the UI and      */\n/* exports the functions marked in the list.                               */\n/***************************************************************************/\n%macro loopThroughFunctionList();\n\t%let i= 1;\n\t%do %until (&i > &_customFunction_count);\n\t\t/* Export custom function */\n\t\t%exportFunction(&&_customFunction_&i);\n\t\t%let i= %eval(&i+1);\n\t%end;\n%mend loopThroughFunctionList;\n\n/***************************************************************************/\n/* Macro outputMsg()                                                       */ \n/* ----------------------------------------------------------------------- */\n/* The macro outputs a list of exported custom functions.                   */\n/***************************************************************************/\n%macro outputMsg();\ndata _null_;\n\tfile print;\n\tput \"Exported custom function(s):\";\n\t%let i= 1;\n\t%do %until (&i > &_customFunction_count);\n\t\tput \"    - &&_customFunction_&i\";\n\t\t%let i= %eval(&i+1);\n\t%end;\t\nrun;\n%mend outputMsg;\n\n/***************************************************************************/\n/* Start executing job                                                     */\n/***************************************************************************/\n/* Check output folder server setting */\n%let outputFolder= %substr(&_outputFolder, 11);\n%let folderserver= %substr(&_outputFolder, 1, 9);\ndata _null_;\n\tfile print;\t\n\tfolderserver= \"&folderserver\";\n\tif folderserver ~= \"sasserver\" then do;\n\t\tput \"ERROR: Wrong output folder!\";\n\t\tput \"Please select a folder from sasserver not from sascontent.\";\n\t\terror \"ERROR: Wrong output folder! The folder needs to be on sasserver!\";\n\t\tabort;\n\tend;\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Get server information */\ndata _null_;\n\tcall symput('server', substr(\"&_baseurl\", 1, prxmatch(\"\\/SASStudio/\\\", \"&_baseurl\") - 1));\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Export custom functions */\n%loopThroughFunctionList();\n\n/* ---------------------------------------------------------------------- */\n/* Outputs a list of exported custom functions. */\n%outputMsg();\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros variables used in this step                                 */\n/* --------------------------------------------------------------------------- */\n%symdel outputFolder;\n%symdel folderserver;\n%symdel funcCode;\n%symdel tmpDir;\n%symdel server;\n\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros used in this step                                           */\n/* --------------------------------------------------------------------------- */\n%sysmacdelete exportFunction; \n"}}