{"creationTimeStamp":"2024-02-21T15:21:48.314Z","modifiedTimeStamp":"2024-02-26T14:50:18.146Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - Read Custom Functions.step","displayName":"ID - Read Custom Functions.step","localDisplayName":"ID - Read Custom Functions.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","uri":"/dataFlows/steps/78bf25dd-4ac2-4781-8c14-f074bcda5164","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[{"name":"_outputtable","displayName":"_outputtable","localDisplayName":"_outputtable","minEntries":0,"maxEntries":1,"defaultEntries":0,"type":"table","supportsView":false,"requiresStructure":false}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Read Custom Functions\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_outputtable\",\n\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\"label\": \"Output table:\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": [\n\t\t\t\t\t\t1,\n\t\t\t\t\t\t\"=\",\n\t\t\t\t\t\t0\n\t\t\t\t\t]\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"This step reads the list of all custom function in SAS Inltelligent Decsioning.\\nUse this step as input step for step 'ID - Export Custom Functions'\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": []\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_outputtable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t}\n\t}\n}","templates":{"SAS":"/***************************************************************************\n* Custom Step:ID - Read Custom Functions\n* --------------------------------------------------------------------------\n* The Read Custom Functions step creates a list of all custom functions in \n* Intelligent Decsioning and output the list to a dataset. The step need to \n* run before using step Export Custom Functions.\n* --------------------------------------------------------------------------\n* Note: Macros starting with an underscore contain UI variable values\n***************************************************************************/\n%let tmpDir= /tmp/;\n%let funcList= ~custfunclist.txt;\n%let catList= ~catlist.txt;\n\n/* ---------------------------------------------------------------------- */\n/* if no output table name is set we set the default name to _RCF_IDCUSTOMFUNCTIONS */\n%if %symexist(_outputtable)=1 and &_outputtable=%then %do; \n    %let _outputtable= _RCF_IDCUSTOMFUNCTIONS;\n%end;\n%if %symexist(_outputtable)=0 %then %do; \n    %let _outputtable= _RCF_IDCUSTOMFUNCTIONS;\n%end;\n\n/* ---------------------------------------------------------------------- */\n/* Get server information */\ndata _null_;\n\tcall symput('server', substr(\"&_baseurl\", 1, prxmatch(\"\\/SASStudio/\\\", \"&_baseurl\") - 1));\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Set URL to read list of custom functions */\ndata _null_;\n\turl= cat('\"', \"&server\", '/businessRules/functions', '\"');\n\tcall symputx('url', url);\n\tput url=;\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Receive list of custom functions */\nfilename CF \"&tmpDir.&funcList\";\nproc http\n\tmethod= \"GET\"   \t\n\turl= &url\n\tout= CF\n    oauth_bearer= sas_services;\n \theaders \n    \t'Content-Type'='application/json';\nquit;\n\n/* ---------------------------------------------------------------------- */\n/* Set URL read list of categories, as the function list has no category names - just the id */\ndata _null_;\n\turl= cat('\"', \"&server\", '/businessRules/functionCategories', '\"');\n\tcall symputx('url', url);\n\tput url=;\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Receive category list */\nfilename CL \"&tmpDir.&catList\";\nproc http\n\tmethod= \"GET\"   \t\n\turl= &url\n\tout= CL\n    oauth_bearer= sas_services;\n \theaders \n    \t'Content-Type'='application/json';\nquit;\n\n/* Read the category and function list and create the export file*/\nproc python;\nsubmit;\nimport json\nimport pandas as pd\n\n# get sas macros into Python\ntmpDir= SAS.symget('tmpDir')\nfuncList= SAS.symget('funcList')\ncatList= SAS.symget('catList')\n\n#read customer function list\nf= open(tmpDir+funcList, 'r')\ncustFuncList= json.loads(f.read())\nf.close()\n\n#Select the fields from the list that we need for the export file\ncustFunctions= []\nfor func in custFuncList['items']:\n    custFunc= []\n    custFunc.append(func['name'])\n    custFunc.append(func['id'])\n    custFunc.append(func['categoryId'])\n    custFunctions.append(custFunc)\n\n#put list into a dataframe/table\ncustFuncTbl= pd.DataFrame(custFunctions, columns=['functionName', 'id', 'categoryId'])\n\n#read the category list\nf= open(tmpDir+catList, 'r')\ncatList= json.loads(f.read())\nf.close()\n\n#get category id and name\ncatNameList= []\nfor cat in catList['items']:\n    catName= []\n    catName.append(cat['name'])\n    catName.append(cat['id'])\n    catNameList.append(catName)\n\n#put list into a dataframe/table\ncatNameTbl= pd.DataFrame(catNameList, columns=['categoryName', 'categoryId'])\n\n#join the two tables custome function and category so we get the category name for each function\ncustFuncNameTbl= pd.merge(custFuncTbl, catNameTbl, how='inner', on=['categoryId'])\n\n#output custom function list to dataset\nSAS.df2sd(custFuncNameTbl, SAS.symget(\"_outputtable\"))\nendsubmit;\nrun; quit;\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros variables used in this step                                 */\n/* --------------------------------------------------------------------------- */\n%symdel tmpDir;\n%symdel funcList;\n%symdel catList;\n%symdel url;\n%symdel server;"}}