{"creationTimeStamp":"2024-02-22T15:32:12.969Z","modifiedTimeStamp":"2024-02-26T15:07:22.078Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"ID - Import Custom Functions.step","displayName":"ID - Import Custom Functions.step","localDisplayName":"ID - Import Custom Functions.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","uri":"/dataFlows/steps/879069f0-cad8-4c30-91c6-ada05479cb74","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Import Custom Functions\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_cf_import_file\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select Custom Function Import File:\",\n\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\"placeholder\": \"Select file from SAS Server\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": []\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_cf_import_file\": \"\"\n\t}\n}","templates":{"SAS":"/***************************************************************************\n* Custom Step:ID - Import Custom Functions\n* --------------------------------------------------------------------------\n* The Import Custom Functions step imports a custom functions to Intelligent \n* Decisioning. It take as input a joson file that was created through step\n* Export Custom Functions.\n* --------------------------------------------------------------------------\n* Note: Macros starting with an underscore contain UI variable values\n***************************************************************************/\n/***************************************************************************/\n/* Macro getCategoryId()                                                   */\n/* ----------------------------------------------------------------------- */\n/* The macro reads the categoryId from the REST call response and puts it  */\n/* into the macro variable categoryId. If the category does not exist the  */\n/* macro variable is set to empty.                                         */\n/***************************************************************************/\n%macro getCategoryId();\n\t%global categoryId;\n\n\tlibname HTTPOUT JSON fileref=HTTPOUT;\n\tproc sql noprint;\n\tselect value\n\t  into :count\n\t  from httpout.alldata\n\t where P= 1\n\t   and P1 = 'count';\n\tquit;\n\n\t%if &count = 1 %then %do;\n\t\tproc sql noprint;\n\t\tselect id \n\t\t  into :categoryId\n\t\t  from httpout.items\n\t\t;\n\t\tquit;\n\t%end;\n\t%else %do;\n\t\t%let categoryId= .;\n\t%end;\n\tlibname HTTPOUT clear;\n\n\t/* remove trailing blanks from macro */\n\tdata _null_;\n\tcall symput('categoryId',trim(\"&categoryId\"));\n\trun;\n\n\t%put ==> existing categoryId=&categoryId.;\n\n%mend getCategoryId;\n\n/***************************************************************************/\n/* Macro createCategory()                                                  */\n/* ----------------------------------------------------------------------- */\n/* The macro creates a category and puts the categoryId into the macro     */\n/* variable categoryId.                                                    */\n/***************************************************************************/\n%macro createCategory();\n\t/* Set URL to to create category */\n\tdata _null_;\n\t\turl= cat('\"', \"&server\", \"/businessRules/functionCategories\", '\"');\n\t\tcall symputx('url', url);\n\t\tput url=;\n\trun;\n\n\t/* create the payload to create the category */\n\tfilename HTTIN TEMP;\n\tdata _null_;\n\t\tfile HTTIN;\n\t\tname= cat('\"name\": \"', \"&categoryName\", '\",');\n\t\tput '{';\n\t\tput name;\n\t\tput '  \"description\": \"\",';\n\t\tput '  \"hidden\": false';\n\t\tput '}';\n\trun;\n\n\t/* create the category */\n\tfilename HTTPOUT TEMP;\n\tproc http\n\t\tmethod= \"POST\"   \t\n\t\turl= &url\n\t\tin= HTTIN \n\t\tout= HTTPOUT\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t'Content-Type'='application/json';\n\tquit;\n\n\t/* read the categoryId */\n\tlibname httpout JSON fileref=HTTPOUT;\n\tproc sql noprint;\n\tselect trim(value) \n\t  into :categoryId\n\t  from httpout.alldata\n\t where P= 1 \n\t   and P1 = 'id';\n\tquit;\n\n\t/* remove trailing blanks from macro */\n\tdata _null_;\n\tcall symput('categoryId',trim(\"&categoryId\"));\n\trun;\n\t%put ==> created categoryId= &categoryId;\n\n%mend createCategory;\n\n/***************************************************************************/\n/* Macro createCustomFunction()                                           */\n/* ----------------------------------------------------------------------- */\n/* The macro creates a custom function and dispays the output message.     */\n/* variable categoryId.                                                    */\n/***************************************************************************/\n%macro createCustomFunction();\n\t/* ---------------------------------------------------------------------- */\n\t/* Set URL to create custom function */\n\tdata _null_;\n\t\turl= cat('\"', \"&server\", \"/businessRules/functionCategories/&categoryId./functions\", '\"');\n\t\tcall symputx('url', url);\n\t\tput url=;\n\trun;\n\t\n\t/* ---------------------------------------------------------------------- */\n\t/* Get custom function information */\n\tfilename HTTPIN \"&cf_import_file\";\n\tfilename HTTPOUT TEMP;\n\tproc http\n\t\tmethod= \"POST\"   \t\n\t\turl= &url\n\t\tin= HTTPIN \n\t\tout= HTTPOUT\n\t    oauth_bearer= sas_services;\n\t \theaders \n\t    \t'Content-Type'='application/json';\n\tquit;\n\t\n\tlibname httpout JSON fileref=HTTPOUT;\n\n\t%let functionname= .;\n\t/* read the functionname */\n\tlibname httpout JSON fileref=HTTPOUT;\n\tproc sql noprint;\n\tselect trim(value)\n\t  into :functionname\n\t  from httpout.alldata\n\t where P= 1 \n\t   and P1 = 'name';\n\tquit;\n\n\t%if \"&functionname\" = \".\" %then %do;\n\t\tproc sql noprint;\n\t\tcreate table _ICF_ERRMSG as\n\t\tselect value\n\t\t  from httpout.alldata\n\t\t where P= 1 \n\t\t   and P1 = 'message';\n\t\tquit;\n\n\t\tdata _null_;\n\t\t\tset WORK._ICF_ERRMSG;\n\t\t\tmsg= tranwrd(value, '\"', \"'\");\n\t\t\tfile print;\n\t\t\terror \"ERROR: Could not crerate custom function!\";\n\t\t\tput msg;\n\t\t\tput \"Check in Intelligent Decisioning if function is hidden.\";\n\t\t\tabort;\n\t\trun;\n\t%end;\n\t%else %do;\n\t\tdata _null_;\n\t\t\tfile print;\n\t\t\tmsg= cat(\"Custom function '\", trim(\"&functionname\"), \"' created successluffy.\");\n\t\t\tput msg;\n\t\trun;\n\t%end;\n\tlibname HTTPOUT clear;\n%mend createCustomFunction;\n\n/***************************************************************************/\n/* Start executing job                                                     */\n/***************************************************************************/\n/* Check output folder server setting */\n%let cf_import_file= %substr(&_cf_import_file, 11);\n%let folderserver= %substr(&_cf_import_file, 1, 9);\ndata _null_;\n\tfile print;\t\n\tfolderserver= \"&folderserver\";\n\tif folderserver ~= \"sasserver\" then do;\n\t\tput \"ERROR: Wrong input folder!\";\n\t\tput \"Please select a file from sasserver not from sascontent.\";\n\t\terror \"ERROR: Wrong input folder! The file needs to be on sasserver!\";\n\t\tabort;\n\tend;\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Read the category name from the input file */\nproc python;\nsubmit;\nimport json\n\nf= open(SAS.symget('cf_import_file'), 'r')\ncustomFunctionInfo= json.loads(f.read())\nf.close()\n\nSAS.symput('categoryName', customFunctionInfo['category'].strip())\nendsubmit;\nquit;\n\n/* ---------------------------------------------------------------------- */\n/* Get server information */\ndata _null_;\n\tcall symput('server', substr(\"&_baseurl\", 1, prxmatch(\"\\/SASStudio/\\\", \"&_baseurl\") - 1));\nrun;\n\n/* ---------------------------------------------------------------------- */\n/* Set URL to get category information */\ndata _null_;\n\turl= cat('\"', \"&server\", \"/businessRules/functionCategories?filter=eq(name,'&categoryName')\", '\"');\n\tcall symputx('url', url);\n\tput url=;\nrun;\n\t\n/* ---------------------------------------------------------------------- */\n/* Get category information */\nfilename HTTPOUT TEMP;\nproc http\n\tmethod= \"GET\"   \t\n\turl= &url\n\tout= HTTPOUT\n    oauth_bearer= sas_services;\n \theaders \n    \t'Content-Type'='application/json';\nquit;\n\n/* ---------------------------------------------------------------------- */\n/* Get the category id and put it into a macro */\n%getCategoryId();\n\n/* ---------------------------------------------------------------------- */\n/* If there is no category we are going to create it first */\n%if \"&categoryId\" = \".\" %then %do;\n\t%createCategory();\n%end;\n\n/* ---------------------------------------------------------------------- */\n/* Going to create the custom function. */\n%createCustomFunction();\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros variables used in this step                                 */\n/* --------------------------------------------------------------------------- */\n%symdel cf_import_file;\n%symdel folderserver;\n%symdel categoryName;\n%symdel url;\n%symdel categoryId;\n%symdel server;\n\n/* --------------------------------------------------------------------------- */\n/* clean up macros used in this step                                           */\n/* --------------------------------------------------------------------------- */\n%sysmacdelete getCategoryId; \n%sysmacdelete createCategory;\n%sysmacdelete createCustomFunction;\n\n/* --------------------------------------------------------------------------- */\n/* delete temp tables in this step                                             */\n/* --------------------------------------------------------------------------- */\nproc datasets lib=work noprint nowarn;\n\tdelete _DQCA_CA_CR \n\t_ICF_ERRMSG;\nrun; quit; \n\n"}}