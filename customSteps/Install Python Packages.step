{"creationTimeStamp":"2024-02-04T18:21:18.465Z","modifiedTimeStamp":"2024-02-13T14:43:47.099Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"Install Python Packages.step","displayName":"Install Python Packages.step","localDisplayName":"Install Python Packages.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","uri":"/dataFlows/steps/87e3cb2a-9005-4efc-9079-57572892f0bb","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Install Packages\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_py_packages\",\n\t\t\t\t\t\"type\": \"textfield\",\n\t\t\t\t\t\"label\": \"List of Python packages:\",\n\t\t\t\t\t\"placeholder\": \"comma separated list\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_py_packages_dir\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Python package directory on sasserver:\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"About\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"The step installs Python libraries which are not in the current Python environment.\\nYou can install the libraries into a specific directory. If the directory is persistent \\nyou only need to install the libraries once. \\nIf the directory is not persistent you need to reinstall the libraries every time you \\nstart SAS Studio.\\nIf no directory is set the libraries are installed into /tmp/viya-addon.\\nTo use the libraries you need to point to the install path before the import command:\\n\\nimport sys\\nsys.path.insert(0, \\\"/tmp/viya-addon\\\") \\nimport mylib\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_py_packages\": \"\",\n\t\t\"_py_packages_dir\": \"\"\n\t}\n}","templates":{"SAS":"proc python;\nsubmit;\n\n#################################################################################\n#The step installs Python libraries which are not in the current Python environment.\n#You can install the libraries into a specific directory. If the directory is persistent \n#you only need to install the library once. \n#If the directory is not persistent you need to reinstall the libraries every time you \n#start SAS Studio.\n#If no directory is set the libraries are installed into /tmp/viya-addon.\n#To use the libraries you need to pint to the install path before the import command:\n#import sys\n#sys.path.insert(0, \"/tmp/viya-addon\") \n#import mylib\n#################################################################################\n\nimport os, sys, subprocess\n#comma separated list of Python packaged to install\nDependentPackages= SAS.symget(\"_py_packages\")\npackageDir= SAS.symget(\"_py_packages_dir\")\n#cut off sasserver:\nif len(packageDir) == 0:\n    packageDir= \"/tmp/viya-addon\"\nelse:\n    packageDir= packageDir[10:]\n\ndpRc= 0\ndpMsg= ''\n\n#################################################################################\n#function to output message and stop executing the step\n#################################################################################\ndef abortStep(msg):\n    print('*******************************************************************')\n    print(msg)\n    print('*******************************************************************')\n    sas_stmt='''\n\t\tdata _null_;\n\t\t\tfile print;\n\t\t\tput \"Error installing Python package! See log for details.\";\n\t\t\terror \"ERROR: Could not install Python package! See message below for more details.\"; \n\t\t\tabort;\n\t\t\trun;\n    '''\n    SAS.submit(sas_stmt)\n\n#########################################################################################\n#we install the packages in a subdirectory in /tmp as this is where we can write.\n#we then add the package directory to the path so Python can find the packes\n#if the subdirectory already exists this means that we have already installed the packages\n#########################################################################################\ndef installPackages(installPackageList):\n    global packageDir\n    rc= 0\n    msg= ''\n\n    dirExist= os.path.exists(packageDir)\n    if not dirExist:\n        print(\"create package dir\")\n        try:\n            os.mkdir(packageDir)\n        except:\n            msg= \"Could not create Python packages directory <\" +packageDir  +\"> in container!\"\n            return -1, msg\n\n    #the packages come in as a comma separated list\n    packages= installPackageList.split(',')\n    for package in packages:\n        try:\n            subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"--upgrade\", \"--no-cache-dir\", \"-t\", packageDir, package])\n        except subprocess.CalledProcessError as err:\n            msg= 'Could not install package: ' + package\n            return err.returncode, msg\n    return rc, msg\n\n#########################################################################################\n#when we load the scirpt we install the Dependent Packages and import them\n#########################################################################################\ndpRc, dpMsg= installPackages(DependentPackages)\nif dpRc == 0:\n    sys.path.insert(0, packageDir)\n    SAS.symput('packageDir', packageDir)\n    SAS.symput('DependentPackages', DependentPackages)\n    print(\"Message: Installed package(s) - \" +DependentPackages)\nelse:\n    abortStep(dpMsg)\n\nendsubmit;\nquit;\n\n\n\ndata _null_;\n\tfile print;\n\tput \"Pathon package(s) successfully installed\";\n\tput \"    Package(s): &DependentPackages\";\n\tput \"    Install directory: &packageDir\";\n\tput \"-----------------------------------------------------------------------\";\n\tput \"To use the package(s) in Python you have to point to install directory:\";\n\tput \"import sys\";\n\tput \"sys.path.insert(0, '&packageDir')\";\n\tput \"import &DependentPackages\";\nrun;"}}