{"creationTimeStamp":"2023-12-20T13:58:13.882Z","modifiedTimeStamp":"2023-12-22T13:47:41.953Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"Generate DI Tables.step","displayName":"Generate DI Tables.step","localDisplayName":"Generate DI Tables.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","uri":"/dataFlows/steps/35f870b9-5215-4e26-9427-4d3ebeaa9278","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[],"outputPorts":[]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Generate Tables\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_spkFile\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select Data Integration Archive:\",\n\t\t\t\t\t\"pathtype\": \"file\",\n\t\t\t\t\t\"placeholder\": \"*.spk\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_libFolder\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Select Library Folder\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t},\n\t\t{\n\t\t\t\"id\": \"page2\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Options\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"This step expects the Python library ‘xmltodict’ to be installed. \\nIf ‘xmltodict’ is not installed you can use the step ‘Install Python \\nPackages’ to install it. If you have used  ‘Install Python Packages’ \\nyou have to set the path where the library was installed.\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_xmltodictPath\",\n\t\t\t\t\t\"type\": \"path\",\n\t\t\t\t\t\"label\": \"Set xmltodict Path\",\n\t\t\t\t\t\"pathtype\": \"folder\",\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"required\": false,\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_spkFile\": \"\",\n\t\t\"_libFolder\": \"\",\n\t\t\"_xmltodictPath\": \"\"\n\t}\n}","templates":{"SAS":"proc python;\nsubmit;\n###################################################################################################\n#From the spk file get the TransportMetadata.xml file and identify the libraries and tables needed \n#for the DI job. We then generate libraries and empty tables. \n#The table are generated to feed the Studio flow with the necessary table meta information. \n#Therefore all libraries will point at the same directory and the tables are empty.\n###################################################################################################\nimport zipfile\nimport sys\n\n#get the path for Python library xmltodict\nxmltodictPath= SAS.symget(\"_xmltodictPath\")\nif xmltodictPath.find(\"sasserver:\") >= 0:\n\txmltodictPath= xmltodictPath[len(\"sasserver:\"):]\nelse:\n\tSAS.symput(\"stepMessage\", \"Incorrect path for xmltodict!\") \n\n#set the path in be able to include the library\nsys.path.insert(0, xmltodictPath)\nimport xmltodict\n\n#################################################################################\n#function to output message and stop executing the step\n#################################################################################\ndef abortStep(msg):\n    print('*******************************************************************')\n    print(msg)\n    print('*******************************************************************')\n    sas_stmt='data _null_;put \"Error installing Python package! See message below for more details.\"; abort;run;'\n    SAS.submit(sas_stmt)\n\n###################################################################################################\n#function to read the libref name. The libref name can be in two different places depending on whether \n#it is a database or a path library. The function looks at the two different palces and returns the \n#libref name.\n###################################################################################################\ndef getLibRef(tab):\n    libObjRef= None\n    dbObjRef= None\n    try:\n        libObjRef= tab['TablePackage']['SASLibrary']['@ObjRef']\n    except:\n        dbObjRef= tab['TablePackage']['DatabaseSchema']['@ObjRef']\n\n    if libObjRef != None:\n        for lib in xmltodict.parse(my_xml)['TransportXml']['SASLibrary']:\n            if lib['@Id'] == libObjRef:\n                return lib['@Libref']\n    else:\n        for lib in xmltodict.parse(my_xml)['TransportXml']['SASLibrary']:\n            try:\n                if lib['UsingPackages']['DatabaseSchema']['@Id'] == dbObjRef:\n                        return lib['@Libref']\n            except:\n                pass\n    return \"\"\n\n###################################################################################################\n#set the spk file information from the UI\nspkFile= SAS.symget(\"_spkFile\")\nif spkFile.find(\"sasserver:\") >= 0:\n\tspkFile= spkFile[len(\"sasserver:\"):]\nelse:\n\tabortStep(\"Incorrect path to SPK File!\") \n\nmetaData= 'TransportMetadata.xml'\n#get TransportMetadata file out of spk file\nwith zipfile.ZipFile(spkFile, 'r') as zip_ref:\n    zip_ref.extractall('/tmp', members=[metaData])\n\n#read the mata data file \nf= open('/tmp/' +metaData, \"r\")\nmy_xml= f.read()\nf.close()\n\n#set the path for the SAS lib we are going to create\nlibFolder= SAS.symget(\"_libFolder\")\nif libFolder.find(\"sasserver:\") >= 0:\n\tlibFolder= libFolder[len(\"sasserver:\"):]\nelse:\n\tabortStep(\"Incorrect path for library folder!\") \n\n#generate the SAS code to create the libraries mentioned in the meta data\n#all libraries will point at the same directory (libFolder)\nsasCode= ''\nfor lib in xmltodict.parse(my_xml)['TransportXml']['SASLibrary']:\n    sasCode+= \"libname \" +lib['@Libref'] +\" '\" +libFolder +\"';\\n\"\n#execute the SAS code\nSAS.submit(sasCode)\n\n#read the table names and their column information from the meta data\nsasTab={}\nfor tab in xmltodict.parse(my_xml)['TransportXml']['PhysicalTable']:\n    tabName= getLibRef(tab) +\".\" +tab['@SASTableName']\n    columns=[]\n    for c in tab['Columns']['Column']:\n        if c['@SASColumnType'] == 'C':\n            columns.append(\"length \" +c['@SASColumnName'] + \" $\" +c['@SASColumnLength'] +\".;\")\n        if c['@SASColumnType'] == 'N':\n            columns.append(\"length \" +c['@SASColumnName'] + \" \" +c['@SASColumnLength'] +\";\")   \n    sasTab[tabName]= columns\n\n#generate the SAS data set code to create the tables mentioned in the meta data \nsasCode=''\nfor tab in sasTab:\n    sasCode+= \"data \" +tab +\";\\n\";\n    for col in sasTab[tab]:\n        sasCode+= \"\\t\" + col +\"\\n\"\n    sasCode+= \"run;\\n\\n\"\n#execute the SAS code\nSAS.submit(sasCode)\nendsubmit;\nrun;"}}