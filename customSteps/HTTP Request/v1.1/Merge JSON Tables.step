{"creationTimeStamp":"2024-11-20T14:11:18.325Z","modifiedTimeStamp":"2024-11-20T14:45:55.012Z","createdBy":"viyademo01","modifiedBy":"viyademo01","name":"Merge JSON Tables.step","displayName":"Merge JSON Tables.step","localDisplayName":"Merge JSON Tables.step","properties":{},"links":[{"method":"GET","rel":"self","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","type":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"alternate","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","type":"application/vnd.sas.data.flow.step.summary"},{"method":"GET","rel":"up","href":"/dataFlows/steps","uri":"/dataFlows/steps","type":"application/vnd.sas.collection","itemType":"application/vnd.sas.data.flow.step.summary"},{"method":"PUT","rel":"update","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","type":"application/vnd.sas.data.flow.step","responseType":"application/vnd.sas.data.flow.step"},{"method":"DELETE","rel":"delete","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195"},{"method":"POST","rel":"copy","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195/copy","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195/copy","responseType":"application/vnd.sas.data.flow.step"},{"method":"GET","rel":"transferExport","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","responseType":"application/vnd.sas.transfer.object"},{"method":"PUT","rel":"transferImportUpdate","href":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","uri":"/dataFlows/steps/55b7f78d-6c6d-41d0-93a4-3d43915c4195","type":"application/vnd.sas.transfer.object","responseType":"application/vnd.sas.summary"}],"metadataVersion":0.0,"version":2,"type":"code","flowMetadata":{"inputPorts":[{"name":"_inputtable","displayName":"_inputtable","localDisplayName":"_inputtable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table"}],"outputPorts":[{"name":"_outputtable","displayName":"_outputtable","localDisplayName":"_outputtable","minEntries":1,"maxEntries":1,"defaultEntries":0,"type":"table","supportsView":false,"requiresStructure":false}]},"ui":"{\n\t\"showPageContentOnly\": true,\n\t\"pages\": [\n\t\t{\n\t\t\t\"id\": \"page1\",\n\t\t\t\"type\": \"page\",\n\t\t\t\"label\": \"Merge JSON Tables\",\n\t\t\t\"children\": [\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_inputtable\",\n\t\t\t\t\t\"type\": \"inputtable\",\n\t\t\t\t\t\"label\": \"Input table:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"_outputtable\",\n\t\t\t\t\t\"type\": \"outputtable\",\n\t\t\t\t\t\"label\": \"Output table:\",\n\t\t\t\t\t\"required\": true,\n\t\t\t\t\t\"placeholder\": \"\",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t},\n\t\t\t\t{\n\t\t\t\t\t\"id\": \"text1\",\n\t\t\t\t\t\"type\": \"text\",\n\t\t\t\t\t\"text\": \"Connect with table from JSON library, that does not have a continues number.\\n\\nThe step will merge all tables from JSON library with the same name as the input table for the continues number. \",\n\t\t\t\t\t\"visible\": \"\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t],\n\t\"syntaxversion\": \"1.3.0\",\n\t\"values\": {\n\t\t\"_inputtable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t},\n\t\t\"_outputtable\": {\n\t\t\t\"library\": \"\",\n\t\t\t\"table\": \"\"\n\t\t}\n\t}\n}","templates":{"SAS":"/***************************************************************************\n* Custom Step: Merge JSON Tables\n* --------------------------------------------------------------------------\n* This custom step megres tables from the JSON library that have same \n* name but with a continues number.\n* --------------------------------------------------------------------------\n* Note: Macros starting with an underscore contain UI variable values\n****************************************************************************/\n\n/* find out how many tables wityh the same name are in the library */\n/* the first table doesn't have a number but all following... */\nproc sql noprint;\n\tselect count(*) as tabCnt\n\tinto :numTables\n\tfrom SASHELP.VSTABLE\n\twhere libname = %tslit(&_inputtable_lib)\n\tand memname like %tslit(&_inputtable_name%)\n\t;\nrun;\n\n\n/* ----------------------------------------------------------------------- */\n/* merge all tables with the same name                                     */\n/* ----------------------------------------------------------------------- */\n%macro mergeTables();\n\tproc sql;\n\t\tcreate table &_outputtable as \n\t\t%let i= 1;\n\t\t%do %until(&i > &numTables);\n\t\t\t%if &i = 1 %then %do;\n\t\t\t\tselect * from &_inputtable_lib..&_inputtable_name\n\t\t\t%end;\n\t\t\t%else %do;\n\t\t\t\tselect * from &_inputtable_lib..&_inputtable_name.&i\n\t\t\t%end;\n\t\t\t%if &i < &numTables %then %do;\n\t\t\t\tunion all\n\t\t\t%end;\n\t\t\t%let i= %eval(&i + 1);\n\t\t%end;\n\t\t;\n\trun;\n%mend mergeTables;\n\n/* run step */\n%mergeTables();\n"}}